# ========== AI 客服（本应用）==========
# 复制为 .env 后填写。勿将含真实密钥的 .env 提交到 Git。

PROJECT_ID=
# 素材检索项目（ai多模态素材中心）；可与 PROJECT_ID（文档 RAG）不同
MEDIA_PROJECT_ID=667b0124-6a5b-413e-b80d-8199e0abb066
# 大模型经中台 MCP chat_completion；密钥配在中台 .env（DASHSCOPE_API_KEY）
# 留空 LLM_MODEL → 使用中台「大模型管理」中的项目型号
# LLM_MODEL=qwen-max

# 官方 Streamable HTTP（默认）
# MCP_CLIENT_TOKEN 须与中台 MCP 网关密钥一致（不是项目 SERVICE_TOKEN）
MCP_TRANSPORT=http
MCP_URL=http://127.0.0.1:8765/mcp
MCP_CLIENT_TOKEN=
MCP_TIMEOUT=120

TOP_K=5
SEARCH_THRESHOLD=0.45
MEDIA_SEARCH_THRESHOLD=0.25

# ---------- Agent / Loop / Harness ----------
# 客户路径：工具调用循环硬顶
MAX_TOOL_LOOPS=8
# 信息不足追问硬顶
MAX_CLARIFY_LOOPS=10

# ---------- 会话存储：PostgreSQL（默认继承中台根 .env 的 DB_*）----------
# DATABASE_URL=postgresql://user:pass@localhost:5432/aibase
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=password
# DB_NAME=aibase
APP_DB_SCHEMA=ai_customer
# LangGraph checkpoint（interrupt 追问恢复）；默认同 APP_DB_SCHEMA
# CHECKPOINT_SCHEMA=ai_customer
# 开发可 true；生产建议 false
ALLOW_MEMORY_CHECKPOINT=true
DB_POOL_MAX_SIZE=10

# ---- 工艺配置助手（ai_quotation 同步推荐 API）----
# 先启动：cd models/ai_quotation && uv run python api.py
PROCESS_CONFIG_URL=http://127.0.0.1:8510
# PROCESS_CONFIG_TOKEN=
PROCESS_CONFIG_TIMEOUT=120

# ---- 多模态素材（中台 schema ai_mutle_base，经 MCP search_media）----
# 项目 service_token 仅在需要直连中台 REST 时使用；客服默认走 MCP，勿把 token 写进代码。
# SERVICE_TOKEN=
