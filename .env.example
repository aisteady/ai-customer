# ========== AI 客服（本应用）==========
# 复制为 .env 后填写。勿将含真实密钥的 .env 提交到 Git。

PROJECT_ID=
DASHSCOPE_API_KEY=

# 官方 Streamable HTTP（默认）
MCP_TRANSPORT=http
MCP_URL=http://127.0.0.1:8765/mcp
MCP_CLIENT_TOKEN=
MCP_TIMEOUT=120

LLM_MODEL=qwen-plus
TOP_K=5
SEARCH_THRESHOLD=0.45

# ---------- 会话存储：PostgreSQL（默认继承中台根 .env 的 DB_*）----------
# DATABASE_URL=postgresql://user:pass@localhost:5432/aibase
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=password
# DB_NAME=aibase
APP_DB_SCHEMA=ai_customer
