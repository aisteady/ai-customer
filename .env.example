# ========== AI 客服（本应用）==========
# 复制为 .env 后填写。勿将含真实密钥的 .env 提交到 Git。

# 中台项目 UUID（必填）：限定知识库检索范围
PROJECT_ID=

# 通义千问 API Key（问答生成必填；不填则降级为仅展示召回）
DASHSCOPE_API_KEY=

# MCP 连接（默认本机中台 MCP）
MCP_HOST=127.0.0.1
MCP_PORT=8765
# 若中台配置了 MCP_TCP_SECRET，这里必须一致
MCP_TCP_SECRET=
MCP_TIMEOUT=120

# 大模型
LLM_MODEL=qwen-plus

# 召回参数
TOP_K=5
SEARCH_THRESHOLD=0.45

# 本地会话库（相对本目录）
SQLITE_PATH=data/chat.db
