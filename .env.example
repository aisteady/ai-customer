# ========== AI 客服（本应用）==========
# 复制为 .env 后填写。勿将含真实密钥的 .env 提交到 Git。

PROJECT_ID=
DASHSCOPE_API_KEY=

# 官方 Streamable HTTP（默认）
MCP_TRANSPORT=http
MCP_URL=http://127.0.0.1:8765/mcp
# 与中台 MCP_CLIENT_TOKEN 一致（开发未配置时可留空）
MCP_CLIENT_TOKEN=
MCP_TIMEOUT=120

# 遗留 TCP（仅当 MCP_TRANSPORT=tcp 且中台 MCP_ENABLE_TCP=true）
# MCP_TRANSPORT=tcp
# MCP_HOST=127.0.0.1
# MCP_PORT=8766
# MCP_TCP_SECRET=

LLM_MODEL=qwen-plus
TOP_K=5
SEARCH_THRESHOLD=0.45
SQLITE_PATH=data/chat.db
